<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox is MANDATORY for Mac App Store. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Outbound network: needed to download models from huggingface.co. -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Inbound network: ONLY if you keep the local inference server (ForgeServer).
         NOTE: even with this entitlement, a sandboxed app's listening socket is
         reachable from the user's own browser. You must still fix the CORS/auth
         issues (see SUBMISSION_CHECKLIST.md, finding H-1) before shipping. -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- User-selected read access so the model browser can import models from
         folders the user explicitly picks (extra model directories). -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- WARNING: There is NO sandbox entitlement that allows the headless
         launcher (HeadlessLauncher.swift) to Process.run() an external `claude`
         binary and let it roam the filesystem. That feature CANNOT ship in a
         Mac-App-Store build. Remove it from the MAS target, or ship that
         capability only in a Developer-ID (non-MAS) build. -->
</dict>
</plist>
